# Environment Variables — copy this to .env and fill in values
# DO NOT commit .env to git!

# Database (Local Development)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_NAME=refconnect

# Session Security — use a long random string (e.g. generate at: https://randomkeygen.com)
SESSION_SECRET=change-this-to-a-long-random-secret-string

# App Environment
NODE_ENV=development

# Port (optional — defaults to 3000)
PORT=3000

# --- Railway will auto-inject these in production ---
# MYSQLHOST=
# MYSQLPORT=
# MYSQLUSER=
# MYSQLPASSWORD=
# MYSQLDATABASE=
